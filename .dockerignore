# ============================================================
# .dockerignore — Backend (Spring Boot)
# Solo excluye lo que NO necesita el build de Maven
# ============================================================

# Build output (se genera dentro del contenedor)
target/

# IDE
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
.metadata

# Maven wrapper (no necesario, la imagen ya trae Maven)
.mvn/
mvnw
mvnw.cmd

# Git
.git/
.gitignore
.gitattributes

# Documentación
README.md
docs/
*.md

# Logs
*.log
logs/

# Environment (no se usan en el build de Maven)
.env
.env.local
.env.*.local

# OS
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Claude Code
.claude/

# Docker
docker-compose*.yml
